{
    "name": "astrocode-editor",
    "version": "1.4.0",
    "description": "Astro Code Editor",
    "main": "app/main.js",
    "author": "Astrogaming057",
    "scripts": {
        "start": "node server/index.js",
        "proxy": "node proxy/index.js",
        "start:app": "electron app/main.js",
        "app": "electron app/main.js",
        "build": "electron-builder",
        "build:win": "electron-builder --win",
        "dist": "electron-builder --publish=never"
    },
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "chokidar": "^3.5.3",
        "clean-css": "^5.3.3",
        "cors": "^2.8.5",
        "discord-rpc": "^4.0.1",
        "express": "^4.18.2",
        "html-minifier-terser": "^7.2.0",
        "http-proxy": "^1.18.1",
        "jsonwebtoken": "^9.0.2",
        "mammoth": "^1.6.0",
        "marked": "^11.1.1",
        "mime-types": "^2.1.35",
        "node-fetch": "^3.3.2",
        "ssh2": "^1.17.0",
        "ssh2-sftp-client": "^12.1.0",
        "terser": "^5.46.1",
        "ws": "^8.14.2"
    },
    "devDependencies": {
        "electron": "^28.3.3",
        "electron-builder": "^24.13.3",
        "electron-packager": "^17.1.2"
    },
    "build": {
        "appId": "com.astrocode.editor",
        "productName": "Astro Code",
        "directories": {
            "output": "dist",
            "buildResources": "build"
        },
        "files": [
            "app/**/*",
            "server/**/*",
            "projects/**/*",
            "node_modules/**/*",
            "package.json"
        ],
        "asarUnpack": [
            "server/**/*",
            "node_modules/**/*"
        ],
        "extraFiles": [
            {
                "from": "start-app.bat",
                "to": "start-app.bat"
            },
            {
                "from": "start-app.vbs",
                "to": "start-app.vbs"
            }
        ],
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "build/icon.ico",
            "sign": null,
            "signingHashAlgorithms": []
        },
        "nsis": {
            "oneClick": false,
            "allowElevation": true,
            "perMachine": true,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "Astro Code",
            "deleteAppDataOnUninstall": false,
            "include": "build/installer.nsh"
        }
    }
}
